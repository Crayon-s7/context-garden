#!/usr/bin/env bash
# ============================================================================
#  cg — Context Garden CLI  (Enhanced UI Edition)
#  管理个人 AI 上下文：Skill、项目上下文、模板、记忆
# ============================================================================
set -euo pipefail

# ── 路径配置 ────────────────────────────────────────────────
CG_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export CG_ROOT

# ── 颜色 ────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  CG_CYAN='\033[36m'
  CG_GREEN='\033[32m'
  CG_YELLOW='\033[33m'
  CG_RED='\033[31m'
  CG_BOLD='\033[1m'
  CG_DIM='\033[2m'
  CG_MAGENTA='\033[35m'
  CG_BLUE='\033[34m'
  CG_WHITE='\033[97m'
  CG_RESET='\033[0m'
  # 背景
  CG_BG_CYAN='\033[46m'
  CG_BG_GREEN='\033[42m'
  CG_BG_DIM='\033[48;5;236m'
else
  CG_CYAN='' CG_GREEN='' CG_YELLOW='' CG_RED=''
  CG_BOLD='' CG_DIM='' CG_MAGENTA='' CG_BLUE=''
  CG_WHITE='' CG_RESET='' CG_BG_CYAN='' CG_BG_GREEN='' CG_BG_DIM=''
fi

# ── 图标 ────────────────────────────────────────────────────
CG_ICON_SKILL="✦"
CG_ICON_PROJECT="◆"
CG_ICON_TEMPLATE="▸"
CG_ICON_MEMORY="◉"
CG_ICON_PROFILE="●"
CG_ICON_SYNC="↑"
CG_ICON_PULL="↓"
CG_ICON_EDIT="✎"
CG_ICON_DELETE="✕"
CG_ICON_HELP="?"

# ── 工具函数 ────────────────────────────────────────────────
cg_info()  { printf "${CG_CYAN}  ℹ${CG_RESET}  %s\n" "$*"; }
cg_ok()    { printf "${CG_GREEN}  ✓${CG_RESET}  %s\n" "$*"; }
cg_warn()  { printf "${CG_YELLOW}  ⚠${CG_RESET}  %s\n" "$*"; }
cg_error() { printf "${CG_RED}  ✗${CG_RESET}  %s\n" "$*" >&2; }

# 分隔线
cg_separator() {
  local width="${1:-50}"
  printf "${CG_DIM}"
  printf '─%.0s' $(seq 1 "$width")
  printf "${CG_RESET}\n"
}

# 双线分隔
cg_double_sep() {
  local width="${1:-50}"
  printf "${CG_DIM}"
  printf '═%.0s' $(seq 1 "$width")
  printf "${CG_RESET}\n"
}

# 横幅
cg_banner() {
  printf "${CG_GREEN}"
  cat <<'BANNER'
   ╔═══════════════════════════════════════════════╗
   ║                                               ║
   ║   🌿  C O N T E X T   G A R D E N            ║
   ║                                               ║
   ║   你的个人 AI 上下文花园                       ║
   ║                                               ║
   ╚═══════════════════════════════════════════════╝
BANNER
  printf "${CG_RESET}"
}

# 横幅（紧凑版）
cg_banner_small() {
  printf "${CG_GREEN}${CG_BOLD}"
  printf "  🌿 Context Garden"
  printf "${CG_RESET}${CG_DIM}"
  printf "  — 你的个人 AI 上下文花园\n"
  printf "${CG_RESET}"
}

# 章节标题
cg_header() {
  local title="$1"
  local icon="${2:-}"
  printf "\n"
  if [[ -n "$icon" ]]; then
    printf "${CG_BOLD}${CG_GREEN}  %s %s${CG_RESET}\n" "$icon" "$title"
  else
    printf "${CG_BOLD}${CG_GREEN}  %s${CG_RESET}\n" "$title"
  fi
  printf "${CG_DIM}  "
  printf '─%.0s' $(seq 1 48)
  printf "${CG_RESET}\n\n"
}

# 从 frontmatter 提取字段值
cg_frontmatter_field() {
  local file="$1" field="$2"
  sed -n "/^---$/,/^---$/p" "$file" \
    | grep "^${field}:" \
    | head -1 \
    | sed "s/^${field}:[[:space:]]*//"
}

# 获取终端宽度
cg_term_width() {
  local w
  w=$(tput cols 2>/dev/null || echo 80)
  [[ $w -lt 40 ]] && w=40
  [[ $w -gt 100 ]] && w=100
  echo "$w"
}

# ── 帮助 ────────────────────────────────────────────────────
cg_help() {
  cg_banner
  printf "\n"
  printf "${CG_DIM}  用法:${CG_RESET} ${CG_BOLD}cg${CG_RESET} ${CG_CYAN}<command>${CG_RESET} ${CG_DIM}[options]${CG_RESET}\n\n"

  # ── 查看类 ──
  printf "${CG_BOLD}${CG_MAGENTA}  📖 查看内容${CG_RESET}\n"
  printf "  ${CG_DIM}─────────────────────────────────────────${CG_RESET}\n"
  printf "  ${CG_CYAN}skills${CG_RESET}                     列出所有 Skill\n"
  printf "  ${CG_CYAN}skill${CG_RESET} ${CG_DIM}<name>${CG_RESET}              查看某个 Skill\n"
  printf "  ${CG_CYAN}skill${CG_RESET} ${CG_DIM}<name>${CG_RESET} ${CG_DIM}<file>${CG_RESET}        查看 Skill 中的特定文件\n"
  printf "  ${CG_CYAN}skill${CG_RESET} ${CG_DIM}<name>${CG_RESET} --all       查看 Skill 目录下所有文件\n"
  printf "  ${CG_CYAN}projects${CG_RESET}                   列出所有项目\n"
  printf "  ${CG_CYAN}context${CG_RESET} ${CG_DIM}<project>${CG_RESET}          查看项目上下文\n"
  printf "  ${CG_CYAN}templates${CG_RESET}                  列出所有模板\n"
  printf "  ${CG_CYAN}template${CG_RESET} ${CG_DIM}<name>${CG_RESET}           查看某个模板\n"
  printf "  ${CG_CYAN}profile${CG_RESET}                    查看个人偏好\n"
  printf "  ${CG_CYAN}memory${CG_RESET} ${CG_DIM}[type]${CG_RESET}              查看记忆文件\n"
  printf "  ${CG_CYAN}status${CG_RESET}                     查看花园概览仪表盘\n\n"

  # ── 生成类 ──
  printf "${CG_BOLD}${CG_MAGENTA}  ⚡ 生成与使用${CG_RESET}\n"
  printf "  ${CG_DIM}─────────────────────────────────────────${CG_RESET}\n"
  printf "  ${CG_CYAN}use${CG_RESET} ${CG_DIM}<skill> <project>${CG_RESET}     拼接 Skill + 项目上下文为完整 prompt\n"
  printf "  ${CG_DIM}  └─ ${CG_CYAN}cg use pitch-coach eventalpha${CG_RESET} ${CG_DIM}# 示例${CG_RESET}\n\n"

  # ── 编辑类 ──
  printf "${CG_BOLD}${CG_MAGENTA}  ✎ 编辑与管理${CG_RESET}\n"
  printf "  ${CG_DIM}─────────────────────────────────────────${CG_RESET}\n"
  printf "  ${CG_CYAN}edit skill${CG_RESET} ${CG_DIM}<name>${CG_RESET}         编辑/创建 Skill\n"
  printf "  ${CG_CYAN}edit context${CG_RESET} ${CG_DIM}<project>${CG_RESET}    编辑/创建项目上下文\n"
  printf "  ${CG_CYAN}edit memory${CG_RESET} ${CG_DIM}<type>${CG_RESET}        编辑记忆文件\n"
  printf "  ${CG_CYAN}edit profile${CG_RESET} ${CG_DIM}<type>${CG_RESET}       编辑个人偏好\n"
  printf "  ${CG_CYAN}delete skill${CG_RESET} ${CG_DIM}<name>${CG_RESET}       删除 Skill\n"
  printf "  ${CG_CYAN}delete context${CG_RESET} ${CG_DIM}<name>${CG_RESET}     删除项目\n\n"

  # ── 同步类 ──
  printf "${CG_BOLD}${CG_MAGENTA}  ↕ 同步${CG_RESET}\n"
  printf "  ${CG_DIM}─────────────────────────────────────────${CG_RESET}\n"
  printf "  ${CG_CYAN}sync${CG_RESET}                       推送本地变更到 GitHub\n"
  printf "  ${CG_CYAN}pull${CG_RESET}                       从 GitHub 拉取最新更新\n"
  printf "  ${CG_CYAN}init${CG_RESET}                       初始化 git 仓库\n"
  printf "  ${CG_CYAN}path${CG_RESET}                       显示仓库路径\n\n"

  # ── 提示 ──
  printf "${CG_BOLD}${CG_YELLOW}  💡 提示${CG_RESET}\n"
  printf "  ${CG_DIM}─────────────────────────────────────────${CG_RESET}\n"
  printf "  ${CG_DIM}•${CG_RESET}  ${CG_CYAN}cg use${CG_RESET} 输出可直接复制给 ChatGPT / Claude / Cursor\n"
  printf "  ${CG_DIM}•${CG_RESET}  Skill 目录可包含多个 ${CG_CYAN}.md${CG_RESET} 文件\n"
  printf "  ${CG_DIM}•${CG_RESET}  ${CG_CYAN}CG_EDITOR${CG_RESET} 环境变量可指定编辑器\n"
  printf "  ${CG_DIM}•${CG_RESET}  无参数运行 ${CG_CYAN}cg${CG_RESET} 显示此帮助\n\n"
}

# ── skills ──────────────────────────────────────────────────
cg_list_skills() {
  local skills_dir="$CG_ROOT/skills"
  if [[ ! -d "$skills_dir" ]]; then
    cg_error "skills 目录不存在: $skills_dir"
    return 1
  fi

  local found=0
  local count=0

  cg_header "Skills" "$CG_ICON_SKILL"

  for skill_dir in "$skills_dir"/*/; do
    [[ -d "$skill_dir" ]] || continue
    local name
    name="$(basename "$skill_dir")"
    local skill_file="$skill_dir/SKILL.md"
    if [[ -f "$skill_file" ]]; then
      local desc
      desc="$(cg_frontmatter_field "$skill_file" "description")"
      local file_count
      file_count=$(find "$skill_dir" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')

      # 卡片式展示
      printf "  ${CG_BOLD}${CG_CYAN}✦ %s${CG_RESET}\n" "$name"
      if [[ -n "$desc" ]]; then
        # 截断过长描述
        if [[ ${#desc} -gt 60 ]]; then
          desc="${desc:0:57}..."
        fi
        printf "    ${CG_DIM}%s${CG_RESET}\n" "$desc"
      else
        printf "    ${CG_DIM}（无描述）${CG_RESET}\n"
      fi
      if [[ $file_count -gt 1 ]]; then
        printf "    ${CG_DIM}📁 ${file_count} 个文件${CG_RESET}\n"
      fi
      printf "\n"
      found=1
      count=$((count + 1))
    fi
  done

  if [[ $found -eq 0 ]]; then
    printf "  ${CG_DIM}还没有任何 Skill${CG_RESET}\n"
    printf "  ${CG_DIM}用 ${CG_CYAN}cg edit skill <name>${CG_DIM} 创建一个${CG_RESET}\n\n"
  else
    printf "  ${CG_DIM}共 ${CG_BOLD}%d${CG_RESET}${CG_DIM} 个 Skill${CG_RESET}\n\n" "$count"
  fi
}

cg_show_skill() {
  local name="$1"
  local mode="${2:-}"
  local skill_dir="$CG_ROOT/skills/$name"
  local skill_file="$skill_dir/SKILL.md"

  if [[ ! -d "$skill_dir" ]]; then
    cg_error "Skill 不存在: $name"
    cg_info "可用 Skill:"
    cg_list_skills
    return 1
  fi

  if [[ "$mode" == "--all" ]]; then
    local first=1
    for f in "$skill_dir"/*.md; do
      [[ -f "$f" ]] || continue
      if [[ $first -eq 0 ]]; then
        printf '\n'
        cg_separator 48
        printf '\n'
      fi
      printf "${CG_BOLD}${CG_CYAN}  ┌─ %s ─${CG_RESET}\n" "$(basename "$f")"
      printf "\n"
      cat "$f"
      first=0
    done
    if [[ $first -eq 1 ]]; then
      cg_warn "Skill 目录下没有 .md 文件: $skill_dir"
    fi
  elif [[ -n "$mode" ]]; then
    local target_file="$skill_dir/$mode"
    if [[ ! -f "$target_file" ]]; then
      target_file="$skill_dir/$mode.md"
    fi
    if [[ ! -f "$target_file" ]]; then
      cg_error "文件不存在: $mode"
      cg_info "Skill \"$name\" 目录下的文件:"
      find "$skill_dir" -maxdepth 1 -type f -name '*.md' -exec basename {} \; | sort | while read -r f; do
        printf "    ${CG_CYAN}%s${CG_RESET}\n" "$f"
      done
      return 1
    fi
    cat "$target_file"
  else
    if [[ ! -f "$skill_file" ]]; then
      cg_error "SKILL.md 不存在: $skill_file"
      cg_info "Skill \"$name\" 目录下的文件:"
      find "$skill_dir" -maxdepth 1 -type f -name '*.md' -exec basename {} \; | sort | while read -r f; do
        printf "    ${CG_CYAN}%s${CG_RESET}\n" "$f"
      done
      return 1
    fi
    cat "$skill_file"

    local other_files=()
    for f in "$skill_dir"/*.md; do
      [[ -f "$f" ]] || continue
      local fname
      fname="$(basename "$f")"
      [[ "$fname" != "SKILL.md" ]] && other_files+=("$fname")
    done

    if [[ ${#other_files[@]} -gt 0 ]]; then
      printf '\n'
      cg_separator 48
      printf "${CG_DIM}  📁 该 Skill 还有 ${#other_files[@]} 个文件:${CG_RESET}\n\n"
      for f in "${other_files[@]}"; do
        printf "    ${CG_CYAN}cg skill %s %s${CG_RESET}\n" "$name" "$f"
      done
      printf "    ${CG_CYAN}cg skill %s --all${CG_RESET} ${CG_DIM}# 查看全部${CG_RESET}\n" "$name"
      printf '\n'
    fi
  fi
}

# ── projects ───────────────────────────────────────────────
cg_list_projects() {
  local projects_dir="$CG_ROOT/projects"
  if [[ ! -d "$projects_dir" ]]; then
    cg_error "projects 目录不存在"
    return 1
  fi

  local found=0
  local count=0

  cg_header "Projects" "$CG_ICON_PROJECT"

  for proj_dir in "$projects_dir"/*/; do
    [[ -d "$proj_dir" ]] || continue
    local name
    name="$(basename "$proj_dir")"
    local ctx_file="$proj_dir/context.md"
    if [[ -f "$ctx_file" ]]; then
      local status
      status="$(cg_frontmatter_field "$ctx_file" "status")"
      local marker="○"
      local marker_color="$CG_DIM"
      [[ "$status" == "active" ]] && marker="●" && marker_color="$CG_GREEN"
      [[ "$status" == "paused" ]] && marker="●" && marker_color="$CG_YELLOW"
      [[ "$status" == "archived" ]] && marker="○" && marker_color="$CG_DIM"

      printf "  ${marker_color}%s${CG_RESET} ${CG_BOLD}${CG_CYAN}%-22s${CG_RESET}" "$marker" "$name"
      if [[ -n "$status" ]]; then
        printf " ${CG_DIM}[%s]${CG_RESET}" "$status"
      fi
      printf "\n"

      # 显示文件数
      local fcount
      fcount=$(find "$proj_dir" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')
      printf "    ${CG_DIM}📁 ${fcount} 个文件${CG_RESET}\n\n"

      found=1
      count=$((count + 1))
    else
      printf "  ${CG_DIM}○ %-22s (无 context.md)${CG_RESET}\n\n" "$name"
      found=1
      count=$((count + 1))
    fi
  done

  if [[ $found -eq 0 ]]; then
    printf "  ${CG_DIM}还没有任何项目${CG_RESET}\n"
    printf "  ${CG_DIM}用 ${CG_CYAN}cg edit context <name>${CG_DIM} 创建一个${CG_RESET}\n\n"
  else
    printf "  ${CG_DIM}共 ${CG_BOLD}%d${CG_RESET}${CG_DIM} 个项目${CG_RESET}\n\n" "$count"
  fi
}

cg_show_context() {
  local project="$1"
  local ctx_file="$CG_ROOT/projects/$project/context.md"
  if [[ ! -f "$ctx_file" ]]; then
    cg_error "项目上下文不存在: $project"
    cg_info "可用项目:"
    cg_list_projects
    return 1
  fi
  cat "$ctx_file"
}

# ── use (拼接 Skill + Context) ─────────────────────────────
cg_use() {
  local skill_name="$1"
  local project_name="$2"
  local skill_dir="$CG_ROOT/skills/$skill_name"
  local skill_file="$skill_dir/SKILL.md"
  local ctx_file="$CG_ROOT/projects/$project_name/context.md"

  local has_skill=0 has_ctx=0
  [[ -d "$skill_dir" ]] && has_skill=1
  [[ -f "$ctx_file" ]] && has_ctx=1

  if [[ $has_skill -eq 0 ]]; then
    cg_error "Skill 不存在: $skill_name"
    return 1
  fi
  if [[ $has_ctx -eq 0 ]]; then
    cg_error "项目上下文不存在: $project_name"
    return 1
  fi

  # 加载 profile
  local profile_content=""
  for pf in about-me.md preferences.md writing-style.md; do
    if [[ -f "$CG_ROOT/profile/$pf" ]]; then
      profile_content+="$(cat "$CG_ROOT/profile/$pf")"$'\n\n'
    fi
  done

  # 头部
  cg_double_sep 52
  printf "${CG_BOLD}${CG_GREEN}  🌿  Context Garden Prompt${CG_RESET}\n"
  printf "${CG_DIM}  Skill: %s  │  Project: %s  │  %s${CG_RESET}\n" \
    "$skill_name" "$project_name" "$(date '+%Y-%m-%d %H:%M')"
  cg_double_sep 52

  printf '\n## 个人偏好\n\n'
  if [[ -n "$profile_content" ]]; then
    printf '%s' "$profile_content"
  else
    printf '（profile/ 目录为空，跳过）\n'
  fi

  printf '\n## Skill: %s\n\n' "$skill_name"
  if [[ -f "$skill_file" ]]; then
    cat "$skill_file"
  fi
  for f in "$skill_dir"/*.md; do
    [[ -f "$f" ]] || continue
    local fname
    fname="$(basename "$f")"
    [[ "$fname" == "SKILL.md" ]] && continue
    printf '\n### %s\n\n' "$fname"
    cat "$f"
  done

  printf '\n## 项目上下文: %s\n\n' "$project_name"
  cat "$ctx_file"

  local faq_file="$CG_ROOT/projects/$project_name/faq.md"
  if [[ -f "$faq_file" ]]; then
    printf '\n## 项目 FAQ: %s\n\n' "$project_name"
    cat "$faq_file"
  fi

  local decisions_file="$CG_ROOT/projects/$project_name/decisions.md"
  if [[ -f "$decisions_file" ]]; then
    printf '\n## 项目决策记录: %s\n\n' "$project_name"
    cat "$decisions_file"
  fi

  printf '\n'
  cg_double_sep 52
  printf "${CG_DIM}  ✓ 复制以上内容到 ChatGPT / Claude / Cursor / Codex 即可使用${CG_RESET}\n"
  cg_double_sep 52
}

# ── templates ──────────────────────────────────────────────
cg_list_templates() {
  local tpl_dir="$CG_ROOT/templates"
  if [[ ! -d "$tpl_dir" ]]; then
    cg_error "templates 目录不存在"
    return 1
  fi

  local found=0
  local count=0

  cg_header "Templates" "$CG_ICON_TEMPLATE"

  for tpl_file in "$tpl_dir"/*.md; do
    [[ -f "$tpl_file" ]] || continue
    local name
    name="$(basename "$tpl_file" .md)"
    local purpose
    purpose="$(cg_frontmatter_field "$tpl_file" "purpose")"

    printf "  ${CG_CYAN}▸ %-22s${CG_RESET}" "$name"
    if [[ -n "$purpose" ]]; then
      if [[ ${#purpose} -gt 50 ]]; then
        purpose="${purpose:0:47}..."
      fi
      printf " ${CG_DIM}%s${CG_RESET}" "$purpose"
    fi
    printf "\n"
    found=1
    count=$((count + 1))
  done

  if [[ $found -eq 0 ]]; then
    printf "  ${CG_DIM}还没有任何模板${CG_RESET}\n\n"
  else
    printf "\n  ${CG_DIM}共 ${CG_BOLD}%d${CG_RESET}${CG_DIM} 个模板${CG_RESET}\n\n" "$count"
  fi
}

cg_show_template() {
  local name="$1"
  local tpl_file="$CG_ROOT/templates/$name.md"
  if [[ ! -f "$tpl_file" ]]; then
    cg_error "模板不存在: $name"
    cg_info "可用模板:"
    cg_list_templates
    return 1
  fi
  cat "$tpl_file"
}

# ── profile ─────────────────────────────────────────────────
cg_show_profile() {
  local profile_dir="$CG_ROOT/profile"

  cg_header "Personal Profile" "$CG_ICON_PROFILE"

  for pf in about-me.md preferences.md writing-style.md; do
    local file="$profile_dir/$pf"
    if [[ -f "$file" ]]; then
      cat "$file"
      printf '\n'
    else
      cg_warn "缺少: profile/$pf"
    fi
  done
}

# ── memory ──────────────────────────────────────────────────
cg_show_memory() {
  local mem_type="${1:-}"
  local mem_dir="$CG_ROOT/memory"
  if [[ -n "$mem_type" ]]; then
    local file
    case "$mem_type" in
      decisions|important-decisions) file="$mem_dir/important-decisions.md" ;;
      weekly|weekly-summary)          file="$mem_dir/weekly-summary.md" ;;
      *)
        cg_error "未知记忆类型: $mem_type"
        cg_info "可用类型: decisions, weekly"
        return 1
        ;;
    esac
    if [[ ! -f "$file" ]]; then
      cg_error "记忆文件不存在: $file"
      return 1
    fi
    cat "$file"
  else
    cg_header "Memory Files" "$CG_ICON_MEMORY"
    for mem_file in "$mem_dir"/*.md; do
      [[ -f "$mem_file" ]] || continue
      local name
      name="$(basename "$mem_file" .md)"
      printf "  ${CG_CYAN}◉ %-22s${CG_RESET} ${CG_DIM}%s${CG_RESET}\n" "$name" "$mem_file"
    done
    printf '\n'
  fi
}

# ── status (仪表盘) ─────────────────────────────────────────
cg_status() {
  cg_banner_small
  printf "\n"

  local skills_count=0 projects_count=0 templates_count=0 memory_count=0
  local profile_count=0

  [[ -d "$CG_ROOT/skills" ]] && skills_count=$(find "$CG_ROOT/skills" -name 'SKILL.md' | wc -l | tr -d ' ')
  [[ -d "$CG_ROOT/projects" ]] && projects_count=$(find "$CG_ROOT/projects" -maxdepth 1 -mindepth 1 -type d | wc -l | tr -d ' ')
  [[ -d "$CG_ROOT/templates" ]] && templates_count=$(find "$CG_ROOT/templates" -maxdepth 1 -name '*.md' | wc -l | tr -d ' ')
  [[ -d "$CG_ROOT/memory" ]] && memory_count=$(find "$CG_ROOT/memory" -maxdepth 1 -name '*.md' | wc -l | tr -d ' ')
  [[ -d "$CG_ROOT/profile" ]] && profile_count=$(find "$CG_ROOT/profile" -maxdepth 1 -name '*.md' | wc -l | tr -d ' ')

  # 概览卡片
  printf "  ${CG_DIM}┌─────────────┬─────────────┬─────────────┬─────────────┐${CG_RESET}\n"
  printf "  ${CG_DIM}│${CG_RESET} ${CG_BOLD}${CG_CYAN}✦ Skills${CG_RESET}    ${CG_DIM}│${CG_RESET} ${CG_BOLD}${CG_CYAN}◆ Projects${CG_RESET} ${CG_DIM}│${CG_RESET} ${CG_BOLD}${CG_CYAN}▸ Templates${CG_RESET}${CG_DIM}│${CG_RESET} ${CG_BOLD}${CG_CYAN}◉ Memory${CG_RESET}    ${CG_DIM}│${CG_RESET}\n"
  printf "  ${CG_DIM}│${CG_RESET} ${CG_BOLD}%-8s${CG_RESET}    ${CG_DIM}│${CG_RESET} ${CG_BOLD}%-8s${CG_RESET}    ${CG_DIM}│${CG_RESET} ${CG_BOLD}%-8s${CG_RESET}    ${CG_DIM}│${CG_RESET} ${CG_BOLD}%-8s${CG_RESET}    ${CG_DIM}│${CG_RESET}\n" \
    "$skills_count" "$projects_count" "$templates_count" "$memory_count"
  printf "  ${CG_DIM}└─────────────┴─────────────┴─────────────┴─────────────┘${CG_RESET}\n"

  # Git 状态
  printf "\n"
  if cd "$CG_ROOT" 2>/dev/null && git rev-parse --is-inside-work-tree &>/dev/null; then
    local branch
    branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')"
    local dirty=0
    git diff --quiet HEAD 2>/dev/null || dirty=1
    [[ -n "$(git ls-files --others --exclude-standard 2>/dev/null)" ]] && dirty=1
    local remote_status="已连接"
    git remote get-url origin &>/dev/null || remote_status="未配置远程"

    printf "  ${CG_BOLD}Git 状态${CG_RESET}\n"
    printf "  ${CG_DIM}─────────────────────────────────────────${CG_RESET}\n"
    printf "  ${CG_DIM}分支:${CG_RESET} ${CG_CYAN}%s${CG_RESET}" "$branch"
    if [[ $dirty -eq 1 ]]; then
      printf "  ${CG_YELLOW}● 有未提交变更${CG_RESET}"
    else
      printf "  ${CG_GREEN}● 干净${CG_RESET}"
    fi
    printf "  ${CG_DIM}远程:${CG_RESET} %s\n" "$remote_status"
  else
    printf "  ${CG_DIM}Git: 未初始化${CG_RESET}\n"
  fi

  # Profile 状态
  printf "\n"
  printf "  ${CG_BOLD}个人偏好${CG_RESET} ${CG_DIM}(%d/3)${CG_RESET}\n" "$profile_count"
  printf "  ${CG_DIM}─────────────────────────────────────────${CG_RESET}\n"
  for pf in about-me preferences writing-style; do
    if [[ -f "$CG_ROOT/profile/${pf}.md" ]]; then
      printf "  ${CG_GREEN}✓${CG_RESET} ${CG_DIM}%s${CG_RESET}\n" "$pf"
    else
      printf "  ${CG_RED}✗${CG_RESET} ${CG_DIM}%s${CG_RESET}\n" "$pf"
    fi
  done

  # 快捷操作
  printf "\n"
  printf "  ${CG_BOLD}快捷操作${CG_RESET}\n"
  printf "  ${CG_DIM}─────────────────────────────────────────${CG_RESET}\n"
  printf "  ${CG_CYAN}cg skills${CG_RESET}      查看所有 Skill\n"
  printf "  ${CG_CYAN}cg projects${CG_RESET}    查看所有项目\n"
  printf "  ${CG_CYAN}cg use <s> <p>${CG_RESET}  生成 AI prompt\n"
  printf "  ${CG_CYAN}cg sync${CG_RESET}        同步到 GitHub\n"
  printf "  ${CG_CYAN}cg pull${CG_RESET}        拉取最新更新\n"
  printf "\n"
}

# ── edit ────────────────────────────────────────────────────
cg_edit() {
  local editor="${CG_EDITOR:-${EDITOR:-vim}}"
  local type="$1"
  local name="${2:-}"

  local file=""
  case "$type" in
    skill)
      [[ -z "$name" ]] && { cg_error "用法: cg edit skill <name>"; return 1; }
      file="$CG_ROOT/skills/$name/SKILL.md"
      if [[ ! -f "$file" ]]; then
        cg_info "创建新 Skill: $name"
        mkdir -p "$CG_ROOT/skills/$name"
        cat > "$file" <<EOF
---
name: $name
description: 什么时候用这个 Skill
version: 1.0
---

# ${name} Skill

## 目标

（这个 Skill 解决什么问题）

## 适用场景

- 

## 输出原则

1. 

## 输出结构

\`\`\`markdown
（输出应该长什么样）
\`\`\`

## 常见追问

- 
EOF
        cg_ok "已创建: $file"
      fi
      ;;
    context)
      [[ -z "$name" ]] && { cg_error "用法: cg edit context <project>"; return 1; }
      file="$CG_ROOT/projects/$name/context.md"
      if [[ ! -f "$file" ]]; then
        cg_info "创建新项目: $name"
        mkdir -p "$CG_ROOT/projects/$name"
        cat > "$file" <<EOF
---
project: $name
status: active
updated: $(date '+%Y-%m-%d')
---

# ${name} - 项目上下文

## 一句话定位

（你的项目是什么）

## 核心痛点

- 

## 当前产品想法

- 

## 已知风险

- 

## 下一步计划

- [ ] 

## 已确定的决策

- 
EOF
        cg_ok "已创建: $file"
      fi
      ;;
    memory)
      local mem_type="${name:-}"
      [[ -z "$mem_type" ]] && { cg_error "用法: cg edit memory <decisions|weekly>"; return 1; }
      case "$mem_type" in
        decisions|important-decisions) file="$CG_ROOT/memory/important-decisions.md" ;;
        weekly|weekly-summary)          file="$CG_ROOT/memory/weekly-summary.md" ;;
        *)
          cg_error "未知记忆类型: $mem_type"
          cg_info "可用: decisions, weekly"
          return 1
          ;;
      esac
      [[ ! -f "$file" ]] && { cg_error "文件不存在: $file"; return 1; }
      ;;
    profile)
      local prof_type="${name:-}"
      [[ -z "$prof_type" ]] && { cg_error "用法: cg edit profile <about-me|preferences|writing-style>"; return 1; }
      file="$CG_ROOT/profile/$prof_type.md"
      [[ ! -f "$file" ]] && { cg_error "文件不存在: $file"; return 1; }
      ;;
    *)
      cg_error "未知编辑类型: $type"
      cg_info "可用: skill, context, memory, profile"
      return 1
      ;;
  esac

  cg_info "用 $editor 打开: $file"
  "$editor" "$file"
}

# ── 冲突检测 ────────────────────────────────────────────────
cg_check_conflicts() {
  local conflicted
  conflicted="$(git diff --name-only --diff-filter=U 2>/dev/null)"
  if [[ -n "$conflicted" ]]; then
    printf "\n"
    cg_error "发现冲突！以下文件需要手动解决："
    while read -r f; do
      [[ -n "$f" ]] && printf "    ${CG_RED}▶ %s${CG_RESET}\n" "$f"
    done <<< "$conflicted"
    printf '\n'
    cg_info "解决步骤："
    printf "    ${CG_DIM}1.${CG_RESET} 编辑上述文件，找到冲突标记 ${CG_YELLOW}<<<<<<< ======= >>>>>>>${CG_RESET}\n"
    printf "    ${CG_DIM}2.${CG_RESET} 保留需要的内容，删除冲突标记\n"
    printf "    ${CG_DIM}3.${CG_RESET} 运行 ${CG_CYAN}cg sync${CG_RESET} 重新提交\n"
    printf "    ${CG_DIM}4.${CG_RESET} 放弃合并: ${CG_CYAN}git merge --abort${CG_RESET} 或 ${CG_CYAN}git rebase --abort${CG_RESET}\n"
    return 1
  fi
  return 0
}

# ── sync ────────────────────────────────────────────────────
cg_sync() {
  cd "$CG_ROOT"

  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    cg_error "不是 git 仓库。请先运行: cg init"
    return 1
  fi

  printf "\n"
  cg_banner_small
  printf "  ${CG_DIM}同步到 GitHub${CG_RESET}\n\n"

  if git diff --quiet HEAD 2>/dev/null && [[ -z "$(git ls-files --others --exclude-standard)" ]]; then
    cg_ok "没有变更，已是最新。"
    printf "\n"
    return 0
  fi

  git add -A

  local changes
  changes="$(git status --short | head -10)"
  local change_count
  change_count="$(git status --short | wc -l | tr -d ' ')"

  local msg="[cg sync] 更新 ${change_count} 个文件

Changed files:
${changes}"

  git commit -m "$msg"
  cg_ok "已提交 ${change_count} 个文件变更。"

  if git remote get-url origin &>/dev/null; then
    local push_output
    push_output="$(git push origin HEAD 2>&1)" || true

    if echo "$push_output" | grep -qi "rejected\|non-fast-forward\|fetch first"; then
      cg_warn "远程有更新，先拉取再推送..."
      local branch
      branch="$(git rev-parse --abbrev-ref HEAD)"

      git pull --rebase origin "$branch" 2>&1 | while read -r line; do
        printf "    %s\n" "$line"
      done

      if ! cg_check_conflicts; then
        return 1
      fi

      git push origin HEAD 2>&1 | while read -r line; do
        printf "    %s\n" "$line"
      done
      cg_ok "已推送到远程仓库。"
    else
      cg_ok "已推送到远程仓库。"
    fi
  else
    cg_warn "没有配置远程仓库 (origin)。跳过推送。"
    cg_info "用以下命令添加远程仓库:"
    printf "    git remote add origin git@github.com:<user>/context-garden.git\n"
  fi
  printf "\n"
}

# ── pull ────────────────────────────────────────────────────
cg_pull() {
  cd "$CG_ROOT"

  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    cg_error "不是 git 仓库。请先运行: cg init"
    return 1
  fi

  if ! git remote get-url origin &>/dev/null; then
    cg_error "没有配置远程仓库 (origin)。"
    return 1
  fi

  printf "\n"
  cg_banner_small
  printf "  ${CG_DIM}从 GitHub 拉取更新${CG_RESET}\n\n"

  local stashed=0
  if ! git diff --quiet HEAD 2>/dev/null || [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
    cg_warn "本地有未提交的变更，先自动暂存 (stash)..."
    git stash -u 2>&1 | while read -r line; do
      printf "    %s\n" "$line"
    done
    stashed=1
  fi

  local branch
  branch="$(git rev-parse --abbrev-ref HEAD)"
  cg_info "从远程拉取更新 (origin/$branch)..."
  git pull origin "$branch" 2>&1 | while read -r line; do
    printf "    %s\n" "$line"
  done

  if ! cg_check_conflicts; then
    if [[ $stashed -eq 1 ]]; then
      cg_warn "你的本地变更仍在 stash 中。"
      cg_info "解决冲突后运行: git stash pop 恢复本地变更"
    fi
    return 1
  fi

  if [[ $stashed -eq 1 ]]; then
    cg_info "恢复本地变更..."
    git stash pop 2>&1 | while read -r line; do
      printf "    %s\n" "$line"
    done
    if ! cg_check_conflicts; then
      cg_info "你的变更仍在 stash 中: git stash list 查看"
      return 1
    fi
  fi

  cg_ok "已是最新。"
  printf "\n"
}

# ── init ───────────────────────────────────────────────────
cg_init() {
  cd "$CG_ROOT"
  if git rev-parse --is-inside-work-tree &>/dev/null; then
    cg_ok "已经是 git 仓库: $(git rev-parse --show-toplevel)"
    return 0
  fi

  cg_info "初始化 git 仓库..."
  git init
  git add -A
  git commit -m "Initial commit: Context Garden V1+V2

- profile/: 个人背景和偏好
- projects/: 长期项目上下文
- skills/: 可复用 AI 工作流
- templates/: 常用输出模板
- memory/: 跨项目重要结论
- bin/cg: 命令行工具
- docs/: 使用说明"

  cg_ok "Git 仓库已初始化并完成首次提交。"
}

# ── path ───────────────────────────────────────────────────
cg_show_path() {
  printf "%s\n" "$CG_ROOT"
}

# ── delete ──────────────────────────────────────────────────
cg_delete() {
  local type="$1"
  local name="${2:-}"

  if [[ -z "$type" || -z "$name" ]]; then
    cg_error "用法: cg delete <skill|context|project> <name>"
    return 1
  fi

  local target_dir=""

  case "$type" in
    skill)
      target_dir="$CG_ROOT/skills/$name"
      if [[ ! -d "$target_dir" ]]; then
        cg_error "Skill 不存在: $name"
        return 1
      fi
      local file_count
      file_count=$(find "$target_dir" -type f | wc -l | tr -d ' ')
      printf "\n"
      cg_warn "将删除 Skill \"$name\" ($file_count 个文件):"
      find "$target_dir" -type f -exec basename {} \; | sort | while read -r f; do
        printf "    ${CG_RED}▶ %s${CG_RESET}\n" "$f"
      done
      ;;
    context|project)
      target_dir="$CG_ROOT/projects/$name"
      if [[ ! -d "$target_dir" ]]; then
        cg_error "项目不存在: $name"
        return 1
      fi
      local file_count
      file_count=$(find "$target_dir" -type f | wc -l | tr -d ' ')
      printf "\n"
      cg_warn "将删除项目 \"$name\" ($file_count 个文件):"
      find "$target_dir" -type f -exec basename {} \; | sort | while read -r f; do
        printf "    ${CG_RED}▶ %s${CG_RESET}\n" "$f"
      done
      ;;
    *)
      cg_error "未知类型: $type"
      cg_info "可用: skill, context (或 project)"
      return 1
      ;;
  esac

  printf "\n  ${CG_BOLD}${CG_YELLOW}确认删除？[y/N]${CG_RESET} "
  read -r confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    cg_info "已取消。"
    return 0
  fi

  rm -rf "$target_dir"
  cg_ok "已删除: $name"
  cg_info "运行 cg sync 同步到 GitHub。"
}

# ── 主入口 ─────────────────────────────────────────────────
main() {
  if [[ $# -eq 0 ]]; then
    cg_help
    return 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    skills|s)
      cg_list_skills
      ;;
    skill)
      [[ $# -lt 1 ]] && { cg_error "用法: cg skill <name> [--all|<file>]"; cg_help; return 1; }
      cg_show_skill "$1" "${2:-}"
      ;;
    projects|p)
      cg_list_projects
      ;;
    context|ctx)
      [[ $# -lt 1 ]] && { cg_error "用法: cg context <project>"; cg_help; return 1; }
      cg_show_context "$1"
      ;;
    use)
      [[ $# -lt 2 ]] && { cg_error "用法: cg use <skill> <project>"; cg_help; return 1; }
      cg_use "$1" "$2"
      ;;
    templates|tpl)
      cg_list_templates
      ;;
    template)
      [[ $# -lt 1 ]] && { cg_error "用法: cg template <name>"; cg_help; return 1; }
      cg_show_template "$1"
      ;;
    profile)
      cg_show_profile
      ;;
    memory|mem)
      cg_show_memory "${1:-}"
      ;;
    status|st)
      cg_status
      ;;
    edit)
      [[ $# -lt 1 ]] && { cg_error "用法: cg edit <skill|context|memory|profile> <name>"; cg_help; return 1; }
      cg_edit "$1" "${2:-}"
      ;;
    delete|rm)
      [[ $# -lt 2 ]] && { cg_error "用法: cg delete <skill|context> <name>"; cg_help; return 1; }
      cg_delete "$1" "$2"
      ;;
    sync)
      cg_sync
      ;;
    pull)
      cg_pull
      ;;
    init)
      cg_init
      ;;
    path)
      cg_show_path
      ;;
    help|--help|-h)
      cg_help
      ;;
    *)
      cg_error "未知命令: $cmd"
      printf '\n'
      cg_help
      return 1
      ;;
  esac
}

main "$@"
